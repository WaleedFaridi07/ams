OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=6

LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_BASE_URL=http://localhost:3000

API_ACCESS_KEY=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

DATABASE_URL=postgresql://ams:ams@localhost:5433/ams

ALLOW_PRIVATE_MCP_HOSTS=false
MCP_SECRET_DEMO=demo-secret
DEMO_MCP_SHARED_SECRET=demo-secret
PUBLIC_API_BASE_URL=http://127.0.0.1:3001

ENABLE_LLM_JUDGE=true
LLM_JUDGE_MODEL=gpt-4o-mini
LLM_JUDGE_CONCURRENCY=1
LLM_JUDGE_TIMEOUT_MS=8000
LLM_JUDGE_MAX_QUEUE=200

ENABLE_CHILD_ORCHESTRATION=true
CHILD_ROUTING_MODE=llm_strict

RAG_TOP_K=4
RAG_MIN_SIMILARITY=
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100
REINDEX_BATCH_SIZE=40
